# ── Blockchain configuration ──────────────────────────────────────
# Get a free Infura or Alchemy key at infura.io / alchemy.com
WEB3_PROVIDER_URL=https://sepolia.infura.io/v3/YOUR_INFURA_PROJECT_KEY

# Your MetaMask wallet private key (export from MetaMask > Account Details)
# ⚠️  Never commit this file with a real private key to GitHub
PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY

# Deployed contract address — fill in after running the deploy script
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS

# Optional: Etherscan API key for contract verification
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY
